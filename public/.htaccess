# Route clean paths (/mcp, /cron) through the front controller and keep the
# Authorization header available to PHP under CGI/FastCGI (Apache strips it
# by default, which breaks MCP Bearer-token auth on shared hosting).
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
</IfModule>
