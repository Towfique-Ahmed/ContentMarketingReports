{
    "name": "towfique-ahmed/content-marketing-reports",
    "description": "Self-hosted content marketing reports dashboard: Search Console, GA4, social media, campaigns, keywords — no external packages required.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-pdo_sqlite": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
