# Deploy hosts (xCloud/PM2) run a plain `npm ci`, which otherwise installs the
# heavy devDependencies (vitest, playwright-core, drizzle-kit, tsx) too. On a
# small instance that install was getting OOM-killed. Everything `next build`
# and `next start` need lives in "dependencies", so skip devDeps here to keep
# the production install small and within memory.
#
# For local development / tests, install them explicitly:
#   npm install --include=dev
omit=dev
audit=false
fund=false
progress=false
